# ════════════════════════════════════════════════
#  TripUnite — front-end .gitignore
# ════════════════════════════════════════════════

# 🔐 Environment / secrets
.env
.env.*
!.env.example

# 📦 Dependencies
/node_modules
/.pnp
.pnp.js

# 🏗️ Production build
/build
/dist

# 🧪 Testing
/coverage

# 💻 Editor
.vscode/
.idea/

# 🖥️ OS
.DS_Store
Thumbs.db

# 🪵 Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 🗃️ Cache
.eslintcache
.stylelintcache
.parcel-cache/
.cache/

# TypeScript
*.tsbuildinfo
